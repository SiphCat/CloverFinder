# Copy this file to .env.local and paste real values from:
# Supabase Dashboard → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LONG_ANON_PUBLIC_KEY_HERE

# Used in password-reset emails and OAuth redirects — use the same host + port you open in the browser
# (e.g. http://localhost:3000 or http://127.0.0.1:3000) so magic links land on a working tab.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server only: copy from Supabase → Settings → API:
#   Legacy tab: **service_role** JWT, OR new keys: **Secret** (`sb_secret_...`).
# Either works in this variable (some docs call the secret `SUPABASE_SECRET_KEY` — that is supported too).
# Needed for: username login lookup, and permanently deleting accounts. Never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional alias (same value as above); supported if your template uses this name only:
# SUPABASE_SECRET_KEY=

# Creates public.finds via npm run db:setup or Dev → "Create finds table"
# Supabase → Project Settings → Database → database password
# SUPABASE_DB_PASSWORD=
# Or full URI: SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR_REF.supabase.co:5432/postgres

# After adding the key, run these once in Supabase → SQL Editor (or npm run db:setup):
# supabase/sql/lookup_email_by_login_identifier.sql
# supabase/sql/storage_avatars.sql   (profile photos)
# supabase/sql/ensure_finds_table.sql  (or cloverfinder_finds_badges_media.sql for badges + Clovermedia)

# Optional: where users email for manual clover badge review (defaults to reviews@cloverfinder.app)
# NEXT_PUBLIC_BADGE_REVIEW_EMAIL=you@yourdomain.com

# Required for automatic clover photo checks (badge upload + find photos with images).
# Get a key at https://platform.openai.com/api-keys then restart: npm run dev
OPENAI_API_KEY=

# Also add these redirect URLs in Supabase → Authentication → URL Configuration:
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/reset-password
